NODE_ENV=development
HUB3_API_URL=http://localhost:4000
HUB3_WEB_URL=http://localhost:3000
HUB3_SESSION_COOKIE_NAME=hub3_session
HUB3_SESSION_TTL_SECONDS=604800
HUB3_OAUTH_STATE_TTL_SECONDS=600
# Managed Postgres recommended: Neon or Supabase session/direct pooler URL
